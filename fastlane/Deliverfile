# Screenshot-only uploads to App Store Connect.
# Usage: fastlane deliver   (from the repo root)
# Auth: fastlane/asc_api_key.json (gitignored — see fastlane/README-KEY.md)

api_key_path("fastlane/asc_api_key.json")

skip_binary_upload(true)
skip_metadata(true)
skip_app_version_update(true)

# Replace whatever is in App Store Connect with fastlane/screenshots/<locale>/
overwrite_screenshots(true)

run_precheck_before_submit(false)

# Don't stop for the interactive HTML-preview confirmation
force(true)
