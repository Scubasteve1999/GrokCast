//
//  DeveloperAPIKey.swift.example
//
//  Copy this file to DeveloperAPIKey.swift (which is gitignored)
//  and paste your xAI developer key below.
//
//  This is ONLY for internal/TestFlight builds so that users don't have to
//  manually enter the key.
//
//  DO NOT commit the real DeveloperAPIKey.swift file.
//

import Foundation

enum DeveloperAPIKey {
  // Replace with your actual key for TestFlight builds
  static let xai: String? = nil  // "YOUR_XAI_API_KEY"

  // Xweather (primary radar provider)
  static let xweatherClientID: String? = nil  // "YOUR_XWEATHER_CLIENT_ID"
  // Secret only — NOT the full `{id}_{secret}` access key (unless id is set separately above).
  static let xweatherClientSecret: String? = nil  // "YOUR_XWEATHER_CLIENT_SECRET"

  static var xweatherMapsAuth: String? {
    guard let id = xweatherClientID, let secret = xweatherClientSecret, !id.isEmpty, !secret.isEmpty
    else {
      return nil
    }
    // Dashboard shows one combined access key: `{client_id}_{client_secret}`.
    if secret.hasPrefix("\(id)_") { return secret }
    return "\(id)_\(secret)"
  }

  /// Optional override for the hosted Grok proxy (Pro subscribers).
  static let grokProxyBaseURL: String? = nil
}

// OpenWeatherMap API key lives in OpenWeatherMapKeys.swift (committed).
enum OpenWeatherMap {
  static var apiKey: String {
    return OpenWeatherMapKeys.currentKey
  }
}
