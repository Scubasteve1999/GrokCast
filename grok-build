  integrate-weatherkit)
    echo "🔄 Integrating WeatherKit (primary source with hybrid fallback)..."
    shift
    PRIMARY_SOURCE=false
    HYBRID_FALLBACK_OPENMETEO=false
    ADD_ALERTS_SUPPORT=false
    UPDATE_WEATHERSTORE=false
    MAP_TO_EXISTING_MODELS=false
    PRESERVE_GROK_INSIGHTS=false
    while [[ $# -gt 0 ]]; do
      case $1 in
        --primary-source)
          PRIMARY_SOURCE=true
          shift
          ;;
        --hybrid-fallback-openmeteo)
          HYBRID_FALLBACK_OPENMETEO=true
          shift
          ;;
        --add-alerts-support)
          ADD_ALERTS_SUPPORT=true
          shift
          ;;
        --update-weatherstore)
          UPDATE_WEATHERSTORE=true
          shift
          ;;
        --map-to-existing-models)
          MAP_TO_EXISTING_MODELS=true
          shift
          ;;
        --preserve-grok-insights)
          PRESERVE_GROK_INSIGHTS=true
          shift
          ;;
        *)
          echo "Unknown option for integrate-weatherkit: $1"
          exit 1
          ;;
      esac
    done

    if $PRIMARY_SOURCE; then
      echo "→ --primary-source: Make WeatherKit the primary source for current/hourly/daily conditions. All changes respect existing architecture."
    fi
    if $HYBRID_FALLBACK_OPENMETEO; then
      echo "→ --hybrid-fallback-openmeteo: Fall back to OpenMeteo on WeatherKit failure or for supplemental data (AQI, pollen, etc). Non-fatal."
    fi
    if $ADD_ALERTS_SUPPORT; then
      echo "→ --add-alerts-support: Integrate WeatherKit alerts (where available) alongside/hybrid with existing NWS support."
    fi
    if $UPDATE_WEATHERSTORE; then
      echo "→ --update-weatherstore: Update WeatherStore orchestration for primary WeatherKit + fallback + alerts refresh."
    fi
    if $MAP_TO_EXISTING_MODELS; then
      echo "→ --map-to-existing-models: Map WeatherKit types (CurrentWeather, HourWeather, etc) to GrokCastWeather / Hourly / Daily models without altering their public shape."
    fi
    if $PRESERVE_GROK_INSIGHTS; then
      echo "→ --preserve-grok-insights: Keep all Grok prompt contexts, weather injection, Storm Spotter etc. unchanged (use mapped fields)."
    fi

    echo "🧹 Removing GrokCast DerivedData..."
    rm -rf ~/Library/Developer/Xcode/DerivedData/GrokCast-* 2>/dev/null || true
    echo "   DerivedData cleaned."
    unset MTL_ENABLE_DEBUG_INFO 2>/dev/null || true
    echo "🔄 Regenerating Xcode project (xcodegen)..."
    /opt/homebrew/bin/xcodegen generate --spec project.yml
    echo "✅ WeatherKit integration support applied (code changes via follow-up edits if needed)."
    ;;

  archive)
    echo "📦 Creating Release archive for TestFlight..."
    shift
    INCREMENT_FLAG=""
    if [[ "${1:-}" == "--increment" ]]; then
      INCREMENT_FLAG="--increment"
    fi
    chmod +x ./Scripts/archive_for_testflight.sh
    ./Scripts/archive_for_testflight.sh $INCREMENT_FLAG
    ;;

  capture-aso)
    echo "📸 Capturing App Store screenshot compositions..."
    shift
    chmod +x ./Scripts/capture_aso_screenshots.sh
    ./Scripts/capture_aso_screenshots.sh "$@"
    ;;

  help|*)
    echo "GrokCast Build Helper"
    echo ""
    echo "Usage: ./grok-build <command> [options]"
    echo ""
    echo "Available commands:"
    echo "  increment-build [--tag]     Bump the Xcode build number"
    echo "  regenerate [--force]        Regenerate the Xcode project from project.yml"
    echo "  generate-icons <1024.png>   Generate all iOS app icon sizes from a 1024x1024 source"
    echo "  clean [--deep]              Clean DerivedData (use --deep for full reset)"
    echo "  radar [many v* flags] ... --v14-faster-perceived-speed --frame-advance-600ms --stronger-crossfade --boost-visual-pop --keep-single-nws   v14 faster perceived speed (600ms advance), stronger crossfade, boost pop, keep single NWS (all isolated to RadarView.swift)"
    echo "  integrate-nws-api --primary-source --update-weatherstore --add-alerts --grid-system --location-aware --create-nws-service --map-to-existing-models --tie-to-alerts-tab --preserve-radar --error-handling --skeletons   Make NWS primary for weather/alerts via grid (follow architecture, preserve radar/non-US)"
    echo "  integrate-weatherkit [--primary-source] [--hybrid-fallback-openmeteo] [--add-alerts-support] [--update-weatherstore] [--map-to-existing-models] [--preserve-grok-insights]   Integrate WeatherKit as primary (hybrid OpenMeteo fallback, alerts, map models, preserve Grok)"
    echo "  archive [--increment]       Release archive → build/GrokCast.xcarchive (TestFlight prep)"
    echo "  capture-aso                 Simulator screenshots → Marketing/AppStore/"
    echo "  help                        Show this help message"
    echo ""
    echo "Examples:"
    echo "  ./grok-build regenerate"
    echo "  ./grok-build regenerate --force"
    echo "  ./grok-build increment-build --tag"
    echo "  ./grok-build generate-icons ~/Desktop/my-icon-1024.png"
    echo "  ./grok-build clean              # Safe: only clears DerivedData"
    echo "  ./grok-build clean --deep       # Full reset (DerivedData + Simulator)"
    echo "  ./grok-build radar --v10-stable-overlay-reuse --force-crossfade-on-anim --enhance-debug --keep-v9-advancement --v11-force-unconditional-reuse --aggressive-stable-guard --loud-reuse-debug --keep-v10-advancement"
    echo "  ./grok-build radar --v14-faster-perceived-speed --frame-advance-600ms --stronger-crossfade --boost-visual-pop --keep-single-nws --build
  ./grok-build integrate-nws-api --primary-source --update-weatherstore --add-alerts --grid-system --location-aware --create-nws-service --map-to-existing-models --tie-to-alerts-tab --preserve-radar --error-handling --skeletons
  ./grok-build integrate-weatherkit --primary-source --hybrid-fallback-openmeteo --add-alerts-support --update-weatherstore --map-to-existing-models --preserve-grok-insights"
    ;;
esac
