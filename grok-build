    fi
    if $LOCATION_AWARE; then
      echo "   --location-aware applied. Follow GrokCast architecture."
    fi
    if $CREATE_NWS_SERVICE; then
      echo "   --create-nws-service applied. Follow GrokCast architecture."
    fi
    if $MAP_TO_EXISTING_MODELS; then
      echo "   --map-to-existing-models applied. Follow GrokCast architecture."
    fi
    if $TIE_TO_ALERTS_TAB; then
      echo "   --tie-to-alerts-tab applied. Follow GrokCast architecture."
    fi
    if $PRESERVE_RADAR; then
      echo "   --preserve-radar applied. Follow GrokCast architecture."
